# Exemplo de variaveis de ambiente da Astra API.
# Em producao, defina estes valores via cofre/secrets e mantenha o .env real
# FORA do versionamento (no .gitignore).

NASA_API_KEY=coloque_sua_chave_aqui
JWT_SECRET=defina_um_segredo_forte
ADMIN_TOKEN=defina_um_token_forte
DB_HOST=localhost
DB_USER=usuario
DB_PASSWORD=senha
DB_NAME=astra
PORT=3001
