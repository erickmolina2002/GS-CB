# Variaveis de ambiente do app Astra (Expo).
# Copie para .env para rodar localmente com o backend proprio (pasta /API):
#
#   cp .env.example .env
#
# Com a variavel abaixo definida, o app roteia todas as chamadas pelo backend
# de proxy. Sem ela (ex.: build web de producao), o app chama as APIs externas
# diretamente.

EXPO_PUBLIC_API_URL=http://localhost:3001
